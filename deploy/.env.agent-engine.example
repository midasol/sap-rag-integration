# =============================================================================
# deploy/.env.agent-engine.example  —  Mode B (Vertex AI Agent Engine standalone)
#
# Copy to deploy/.env.agent-engine and fill in real values, then run
#   ./deploy/setup-agent-engine.sh <PROJECT_ID>
#   python deploy/deploy-agent-engine.py --project <PROJECT_ID>
#
# See deploy/README.md for the Mode A vs Mode B decision matrix.
# =============================================================================

# ---- GCP target ----------------------------------------------------------
PROJECT_ID=
REGION=us-central1
# Default: gs://${PROJECT_ID}_cloudbuild
STAGING_BUCKET=

# ---- Cloud SQL (managed by setup-cloud-sql.sh) ---------------------------
# CLOUD_SQL_PASSWORD and CLOUD_SQL_PRIVATE_IP are auto-written by
# setup-cloud-sql.sh when invoked with MODE=agent-engine. Don't hand-edit.
CLOUD_SQL_INSTANCE=sapphire26-adk-db
CLOUD_SQL_DB=sapphire26_adk
CLOUD_SQL_USER=app
CLOUD_SQL_PASSWORD=replace-me
CLOUD_SQL_PRIVATE_IP=

# ---- Network (PSC for Agent Engine → SAP + Cloud SQL Private IP) --------
# Same VPC must host both the SAP S/4HANA gateway and the Cloud SQL Private
# IP peering. setup-cloud-sql.sh enables PSA peering on this network.
VPC_NETWORK=
PSC_SUBNET_NAME=psc-attachment-subnet
PSC_SUBNET_RANGE=192.168.10.0/28
NETWORK_ATTACHMENT_NAME=agent-engine-attachment

# ---- Secret Manager ------------------------------------------------------
# JSON blob with SAP OAuth client/secret/host/etc. Created by
# setup-agent-engine.sh — populate with `gcloud secrets versions add`.
SAP_CREDENTIALS_SECRET=sap-credentials
# Fernet key (44 chars). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SAP_CRED_ENCRYPTION_KEY_SECRET=sap-cred-encryption-key

# ---- Service account -----------------------------------------------------
AGENT_ENGINE_SA=agent-engine-sa

# ---- ADK runtime tunables -----------------------------------------------
SAP_AGENT_MODEL=gemini-3.1-pro-preview
EMBED_MODEL=gemini-embedding-2
EMBED_OUTPUT_DIM=3072
EMBED_NORMALIZE=true
ADK_SESSION_BACKEND=vertex

# ---- Resource limits (agent_engines.create kwargs) ----------------------
# cpu: "1" | "2" | "4" | "6" | "8"
# memory: "1Gi" .. "32Gi"
AGENT_CPU=4
AGENT_MEMORY=8Gi

# ---- Gemini Enterprise registration --------------------------------------
# Cosmetic only — used in the deploy summary printout.
AGENT_DISPLAY_NAME=sapphire26 SAP RAG Agent
