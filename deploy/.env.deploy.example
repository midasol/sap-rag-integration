# =============================================================================
# deploy/.env.deploy.example  —  Mode A (Cloud Run × 2)
#
# Copy to deploy/.env.deploy and fill in real values, then run
#   ./deploy/deploy-cloud-run.sh <PROJECT_ID>
#
# See deploy/README.md for the Mode A vs Mode B decision matrix.
# =============================================================================

# ---- Cloud SQL (shared by both modes) -------------------------------------
# CLOUD_SQL_PASSWORD is auto-managed: setup-cloud-sql.sh writes it here on
# first run (auto-generated) and re-reads it on subsequent runs. If you want
# to change the password, edit it here and re-run setup-cloud-sql.sh — the
# script will push the new value to Cloud SQL so the two stay in sync.
CLOUD_SQL_INSTANCE=sapphire26-adk-db
CLOUD_SQL_DB=sapphire26_adk
CLOUD_SQL_USER=app
CLOUD_SQL_PASSWORD=replace-me

# ---- Next.js runtime ------------------------------------------------------
GEMINI_API_KEY=replace-me
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
GEMINI_CHAT_MODEL=gemini-3.1-pro-preview
GCS_BUCKET_NAME=replace-me
GCS_PROJECT_ID=replace-me
# 32+ chars; generate with: openssl rand -base64 48
SAP_SESSION_SECRET=replace-me
# Recommended in production: gates protected API routes at the proxy layer.
REQUIRE_AUTH=true

# ---- ADK agent runtime ----------------------------------------------------
SAP_AGENT_MODEL=gemini-3.1-pro-preview
EMBED_MODEL=gemini-embedding-001
EMBED_OUTPUT_DIM=3072
EMBED_NORMALIZE=true
# Fernet key. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SAP_CRED_ENCRYPTION_KEY=replace-me
SAP_AUTH_TYPE=basic
SAP_HOST=
SAP_PORT=44300
SAP_CLIENT=100
SAP_VERIFY_SSL=true
ADK_SESSION_BACKEND=memory

# ---- VPC for adk_agent → SAP S/4HANA private IP ---------------------------
# When SAP_HOST is an RFC-1918 private IP (10.x / 172.16-31.x / 192.168.x),
# deploy-cloud-run.sh auto-derives:
#   VPC_NETWORK        = the network of the GCE instance that owns SAP_HOST
#   VPC_CONNECTOR_NAME = "<VPC_NETWORK>-connector"
# Leave VPC_NETWORK / VPC_CONNECTOR_NAME blank to use auto-detection.
# Override only when auto-detection picks the wrong network or you want a
# custom connector name. Public SAP host: leave VPC_CONNECTOR_NAME empty.
VPC_NETWORK=
VPC_CONNECTOR_NAME=
CONNECTOR_IP_RANGE=10.8.0.0/28
SAP_TARGET_TAG=
FIREWALL_RULE_NAME=allow-cloudrun-to-sap

# ---- SAP OAuth (optional — only when SAP_AUTH_TYPE=sap_oauth) -------------
SAP_OAUTH_CLIENT_ID=
SAP_OAUTH_CLIENT_SECRET=
SAP_OAUTH_TOKEN_URL=
SAP_OAUTH_AUTHORIZE_URL=
# Mode A: https://<nextjs-cloud-run-url>/api/sap/oauth/callback
SAP_OAUTH_REDIRECT_URI=
