# ---------------------------------------------------------------------------
# REQUIRED
# ---------------------------------------------------------------------------

# Google Gemini API key. Used by the Next.js app for embeddings + chat.
# Create one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# PostgreSQL connection URL (with pgvector extension).
# Example: postgresql://localhost:5432/gemini_rag
DATABASE_URL=

# Google Cloud Storage bucket where uploaded files are stored.
# The bucket must exist in the GCS_PROJECT_ID below.
GCS_BUCKET_NAME=

# GCP project that owns the bucket above and the service account below.
GCS_PROJECT_ID=

# Path to the GCP service account JSON key file.
#
# Used by the Next.js app (src/lib/gcs.ts) to authenticate to Google Cloud
# Storage for file upload/download. Without this (and without ADC), all GCS
# operations fail at runtime.
#
# - Recommended: run `pnpm gcp:setup` to create the service account, generate
#   the key, and fill this in automatically.
# - Manual alternative: see README "Service Account & Credentials" section.
# - If left empty, the SDK falls back to Application Default Credentials
#   (https://cloud.google.com/docs/authentication/application-default-credentials).
GOOGLE_APPLICATION_CREDENTIALS=

# ---------------------------------------------------------------------------
# MODEL OVERRIDES (optional — defaults are usually fine)
# ---------------------------------------------------------------------------
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_CHAT_MODEL=gemini-3.1-pro-preview

# ---------------------------------------------------------------------------
# Session signing key (REQUIRED)
# ---------------------------------------------------------------------------
# Used by iron-session to sign the `sap_session` cookie that scopes
# conversations per SAP user. Must be at least 32 characters.
# Generate one with:  openssl rand -base64 48
SAP_SESSION_SECRET=

# ---------------------------------------------------------------------------
# Logging (Next.js + ADK agent share these variable names)
# ---------------------------------------------------------------------------

# Log verbosity: debug | info | warn | error  (default: info)
LOG_LEVEL=info

# SAP response payload depth: meta (status + counts) | full (response body)
# Keep at "meta" for normal use. Switch to "full" only when deep-diving a
# specific failure, since file size grows quickly.
LOG_PAYLOAD=meta

# Console output format: pretty (colored, dev) | json (machine-readable, prod)
# File output is always JSON regardless of this setting.
LOG_FORMAT=pretty

# Where per-process log files land (created at startup if missing)
LOG_DIR=./logs

# ---------------------------------------------------------------------------
# Auth gate (proxy.ts — see src/proxy.ts)
# ---------------------------------------------------------------------------
# When set to "true", protected API routes are gated by the iron-session
# cookie at the proxy layer in addition to per-handler `requireSession()`.
# Recommended for any deployed/exposed environment. Default (unset) is no-op.
#
# Protected: /api/chat, /api/embed, /api/conversations, /api/pipeline/*,
#            /api/files/*, /api/sap/services
# Excluded:  /api/sap/auth (the login endpoint itself)
REQUIRE_AUTH=

# ---------------------------------------------------------------------------
# ADK backend (REQUIRED — Next.js proxies all chat + SAP calls to it)
# ---------------------------------------------------------------------------
# Base URL of the ADK Python agent (adk_agent/server.py). Default port: 8200.
# `pnpm predev` checks `${ADK_BASE_URL}/healthz` and refuses to boot if the
# agent isn't running.
ADK_BASE_URL=http://localhost:8200
